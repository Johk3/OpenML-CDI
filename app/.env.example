DATABASE_URI=sqlite:///./app_dev.db
# Appended after password, makes breaking hashes more difficult
HASHING_PEPPER=thebestsecret
# run `openssl genpkey -algorithm ed25519 -outform PEM | grep -v '^-' | tr -d '\n'`
JWT_SECRET=verysecret
EMAIL_BACKEND=console
EMAIL_FROM=noreply@example.com
APP_BASE_URL=http://localhost:8000
EMAIL_VERIFICATION_TTL_HOURS=24
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
# Used to prevent timing attacks by checking against a DUMMY_HASH instead of instant return
DUMMY_HASH=$argon2id$v=19$m=65536,t=3,p=4$wMlKGLqzeDNy9N6mXbqsPA$MQoqx76CGvSDGRvo/+ve/ATlxTRyjaUscLKkRnmMlVc
REFRESH_TOKEN_EXPIRY_DAYS=7
ACCESS_TOKEN_EXPIRY_MINUTES=5
OAUTHLIB_INSECURE_TRANSPORT=1 # for dev
GITHUB_CLIENT_ID=x
GITHUB_SECRET=x
GITHUB_REDIRECT=http://localhost:5173/login/callback
