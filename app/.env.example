DATABASE_URI=sqlite:///./app_dev.db
# run `openssl genpkey -algorithm ed25519 -outform PEM | grep -v '^-' | tr -d '\n'`
JWT_SECRET=verysecret
EMAIL_BACKEND=console
EMAIL_FROM=noreply@example.com
APP_BASE_URL=http://localhost:8000
EMAIL_VERIFICATION_TTL_HOURS=24
LOCAL_UPLOAD_DIR=.local_uploads
QUARANTINE_DIR=.quarantine
STORAGE_BACKEND=local
S3_BUCKET=openml-upload-local
S3_REGION=eu-west-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_FORCE_PATH_STYLE=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CLAMD_SOCKET=
CLAMD_HOST=127.0.0.1
CLAMD_PORT=3310
CLAMD_TIMEOUT_SECONDS=10
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
REFRESH_TOKEN_EXPIRY_DAYS=7
ACCESS_TOKEN_EXPIRY_MINUTES=5
OAUTHLIB_INSECURE_TRANSPORT=1 # for dev
COOKIE_SECURE=false # set true when serving auth over HTTPS
AUTH_DEV_MODE_APPROVE_ALL_LOGINS=false
AUTH_DEV_LOGIN_EMAIL=dev.user@example.com
AUTH_DEV_LOGIN_USERNAME=dev-user
AUTH_DEV_LOGIN_FIRST_NAME=Dev
AUTH_DEV_LOGIN_LAST_NAME=User
GITHUB_CLIENT_ID=x
GITHUB_SECRET=x
GITHUB_REDIRECT=http://localhost:5173/login/callback
GH_APP_ID=
GH_INSTALL_ID=
GH_PRIV_KEY=
GITHUB_ISSUES_OWNER=openml
GITHUB_ISSUES_REPO=openmlupload-test
